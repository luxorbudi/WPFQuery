<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wpf="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
    xmlns:local="clr-namespace.Lens.ViewModels"
    xmlns:ViewModels="clr-namespace:Lens.ViewModels"
    xmlns:System="clr-namespace:System;assembly=mscorlib" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Lens.MainWindow" 
    Title="Consultas Recaudos" Height="665" Width="959" ResizeMode="CanMinimize" 
    WindowStartupLocation="CenterScreen" Icon="icon.png">

    <Window.Resources>
        <!-- This automatically targets every DatePickerTextBox in scope -->
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="./background.png"/>
        </Grid.Background>

        <Border CornerRadius="20,0,20,0" Margin="23,28,746,532">
            <Border.Background>
                <ImageBrush ImageSource="./logo.png" Stretch="Fill"/>
            </Border.Background>
        </Border>

        <Label Content="CONSULTAS DE TABLAS DE RECAUDOS" 
            HorizontalAlignment="Left" Margin="347,41,0,0" 
            VerticalAlignment="Top" Height="39" Width="480" FontSize="24" 
            FontFamily="./resources/fonts/#Tiempos Headline" Foreground="White" />

        <Border BorderBrush="White" 
            BorderThickness="2" Padding="5" 
            CornerRadius="10" Margin="23,122,746,18">

            <Grid>
                <Grid x:Name="EnvironmentGrid">
                    <Grid.DataContext>
                        <ViewModels:EnvironmentViewModel/>
                    </Grid.DataContext>

                    <ComboBox 
                        x:Name="EnvCbo"
                        VerticalAlignment="Top"
                        SelectedItem="{Binding Selected}"
                        Style="{StaticResource ModernComboBoxStyle}" ItemsSource="{Binding EnvironmentItems}"
                        DisplayMemberPath="EnvironmentName" SelectedValuePath="Id" FontSize="14" Margin="10,30,10,0"/>

                    <Label Content="AMBIENTE:" HorizontalAlignment="Left" 
                        VerticalAlignment="Top" Foreground="White" FontSize="16" 
                        Margin="10,1,0,0" FontFamily="./resources/fonts/#Tiempos Headline" />
                </Grid>

                <Grid x:Name="QueryGrid">
                    <Grid.DataContext>
                        <ViewModels:QueryViewModel/>
                    </Grid.DataContext>

                    <Label Content="CONSULTA:" Margin="10,73,0,0" 
                        HorizontalAlignment="Left" VerticalAlignment="Top" 
                        FontFamily="./resources/fonts/#Tiempos Headline" Foreground="White" FontSize="16" />

                    <ComboBox
                        x:Name="QueryCbo"
                        SelectedItem="{Binding Selected}"
                        Margin="10,102,10,0" VerticalAlignment="Top"
                        Style="{StaticResource ModernComboBoxStyle}" ItemsSource="{Binding QueryItems}"
                        DisplayMemberPath="QueryName" SelectedValuePath="Id" FontSize="14" />
                </Grid>

                <Grid x:Name="AgreementGrid">
                    <Label Content="CONVENIO:" Margin="10,147,0,0"
                        HorizontalAlignment="Left" VerticalAlignment="Top" 
                        FontFamily="./resources/fonts/#Tiempos Headline" Foreground="White" FontSize="16" />

                    <TextBox
                        TextWrapping="Wrap"
                        x:Name="AgreementTxt"
                        Style="{StaticResource ModernTextBox}" 
                        VerticalAlignment="Top" Height="31" Margin="10,176,10,0"/>
                </Grid>

                <Grid x:Name="RowsShownGrid">
                    <Grid.DataContext>
                        <ViewModels:RowsShownViewModel/>
                    </Grid.DataContext>

                    <Label Content="N° FILAS:" Margin="10,227,0,0"
                        HorizontalAlignment="Left" VerticalAlignment="Top" 
                            FontFamily="./resources/fonts/#Tiempos Headline" Foreground="White" FontSize="16" />

                    <ComboBox
                            SelectedItem="{Binding Selected}"
                                Margin="96,227,10,0" VerticalAlignment="Top"
                                    Style="{StaticResource ModernComboBoxStyle}" ItemsSource="{Binding RowsShownItems}"
                                            DisplayMemberPath="RowShownName" SelectedValuePath="Id" FontSize="14" Height="30" />
                </Grid>

                <Grid x:Name="StartDateGrid">
                    <Label Content="FECHA INICIO:" Margin="10,270,0,0"
                        HorizontalAlignment="Left" VerticalAlignment="Top" 
                            FontFamily="./resources/fonts/#Tiempos Headline" Foreground="White" FontSize="16" />

                    <DatePicker x:Name="StartDatePicker"
                        Style="{StaticResource ModernDatePicker}" 
                            Loaded="StartDatePicker_Loaded" DisplayDateStart="2022/01/01"
                                Margin="10,299,10,0"
                                    VerticalAlignment="Top" RenderTransformOrigin="0.545,-0.057" Height="35"
                                        DisplayDateEnd="{Binding Mode=OneWay, Source={x:Static System:DateTime.Today}}"/>
                </Grid>

                <Grid x:Name="EndDateGrid" Margin="0,1,0,-1">
                    <Label Content="FECHA FIN:" Margin="10,345,0,0"
                        HorizontalAlignment="Left" VerticalAlignment="Top" 
                            FontFamily="./resources/fonts/#Tiempos Headline" Foreground="White" FontSize="16" />

                    <DatePicker x:Name="EndDatePicker"
                        Style="{StaticResource ModernDatePicker}" 
                            Loaded="StartDatePicker_Loaded" DisplayDateStart="2022/01/01"
                                Margin="10,374,10,0"
                                    VerticalAlignment="Top" RenderTransformOrigin="0.545,-0.057" Height="35"
                                        DisplayDateEnd="{Binding Mode=OneWay, Source={x:Static System:DateTime.Today}}"/>

                    <Button 
                        x:Name="ConsultButton"
                            Click="ConsultButton_Click"
                                Style="{StaticResource ModernElegantButton}" 
                                    Content="Consultar" HorizontalAlignment="Center" Margin="0,426,0,0" 
                                        VerticalAlignment="Top" RenderTransformOrigin="-0.368,0.523" Width="93" Height="35"/>
                </Grid>
            </Grid>
        </Border>
        <DataGrid d:ItemsSource="{d:SampleData ItemCount=5}" Margin="230,122,29,18"/>
    </Grid>
</Window>
